{
  "expo": {
    "name": "SunVantage",
    "slug": "SunVantage",
    "version": "1.0.3",
    "orientation": "portrait",
    "icon": "./assets/sunvantage-app-icon-1024.png",
    "scheme": "sunvantage",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#0E223D",
    "splash": {
      "image": "./assets/images/splash-full.png",
      "resizeMode": "cover",
      "backgroundColor": "#0E223D"
    },
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "buildNumber": "7",
      "bundleIdentifier": "com.sunvantage.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Capture sunrise moments in SunVantage.",
        "NSPhotoLibraryUsageDescription": "Upload sunrise photos to your journal.",
        "NSPhotoLibraryAddUsageDescription": "Save sunrise photos from SunVantage.",
        "NSLocationWhenInUseUsageDescription": "Used to identify your city and nearby sunrise vantage points."
      }
    },
    "android": {
      "versionCode": 7,
      "statusBar": {
        "backgroundColor": "#0E223D",
        "barStyle": "light-content"
      },
      "navigationBar": {
        "backgroundColor": "#0E223D"
      },
      "adaptiveIcon": {
        "backgroundColor": "#1a2442",
        "foregroundImage": "./assets/sunvantage-android-foreground.png",
        "backgroundImage": "./assets/sunvantage-android-background.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "package": "com.sunvantage.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/sunvantage-favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Used to identify your city and nearby sunrise vantage points."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-full.png",
          "resizeMode": "cover",
          "backgroundColor": "#0E223D",
          "enableFullScreenImage_legacy": true,
          "dark": {
            "image": "./assets/images/splash-full.png",
            "backgroundColor": "#0E223D"
          },
          "android": {
            "image": "./assets/images/splash-full.png",
            "resizeMode": "cover",
            "backgroundColor": "#0E223D"
          },
          "ios": {
            "image": "./assets/images/splash-full.png",
            "resizeMode": "cover",
            "backgroundColor": "#0E223D",
            "enableFullScreenImage_legacy": true
          }
        }
      ],
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/sunvantage-android-foreground.png",
          "color": "#1a2442",
          "defaultChannel": "sunrise-reminders"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e31f8162-a0b1-451c-aadb-b05b056ef9a8"
      }
    }
  }
}
